# TEMFPA V.2 environment variables
# Copy to .env and fill in values

# Database (defaults to SQLite; swap to PostgreSQL for production)
DATABASE_URL=sqlite:///./temfpa_v2.db

# Optional API keys — system works without these using free scrapers
API_FOOTBALL_KEY=
FOOTBALL_DATA_KEY=
STATSBOMB_KEY=

# Model settings
MODEL_VERSION=2.0.0
LOG_LEVEL=INFO
